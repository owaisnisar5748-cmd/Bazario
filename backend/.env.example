# Local development can use mongodb://localhost:27017.
# Production should use a MongoDB Atlas connection string.
MONGODB_URL=mongodb://localhost:27017
MONGODB_HOST=localhost
DATABASE_NAME=bazario_db
APP_ENV=development
# Used by the production Docker Compose Mongo service.
MONGO_INITDB_ROOT_USERNAME=bazario
MONGO_INITDB_ROOT_PASSWORD=replace-with-a-strong-database-password
# Generate this with: python scripts/rotate_secret_key.py
SECRET_KEY=replace-with-a-long-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
ALLOWED_ORIGINS=http://localhost:3000
ALLOWED_HOSTS=*

# Public authentication rate limits. Values are per client IP and email identity.
LOGIN_RATE_LIMIT=10
LOGIN_RATE_WINDOW_SECONDS=300
REGISTER_RATE_LIMIT=5
REGISTER_RATE_WINDOW_SECONDS=600
PASSWORD_RESET_RATE_LIMIT=5
PASSWORD_RESET_RATE_WINDOW_SECONDS=900
OTP_SEND_RATE_LIMIT=5
OTP_SEND_RATE_WINDOW_SECONDS=600
OTP_VERIFY_RATE_LIMIT=10
OTP_VERIFY_RATE_WINDOW_SECONDS=600
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_RESEND_SECONDS=30
OTP_VERIFICATION_MINUTES=15
# Keep this true for local development if SMTP/Twilio are not configured.
# Set this to false in production and configure real MAIL_* or TWILIO_* credentials.
OTP_ALLOW_DEV_CODE=true
# auto = require verification when email/SMS/dev OTP is available, otherwise allow signup.
# Set true after configuring real OTP delivery in production.
REGISTRATION_REQUIRE_VERIFICATION=auto
DEFAULT_PHONE_COUNTRY_CODE=+91

# SMTP email OTP delivery. For Gmail, use an App Password rather than your normal password.
MAIL_USERNAME=you@example.com
MAIL_PASSWORD=
MAIL_FROM=you@example.com
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_STARTTLS=true
MAIL_SSL_TLS=false

# Twilio SMS OTP delivery. Phone numbers must use E.164 format.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Razorpay test keys are recommended during development. Switch to live keys only
# after completing Razorpay account activation and webhook/payment testing.
RAZORPAY_KEY_ID=your-key-id
RAZORPAY_KEY_SECRET=your-key-secret

CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
